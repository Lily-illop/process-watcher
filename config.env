# ============================================
# Конфигурация Proc Watcher
# ============================================

# === Общие настройки ===
LOG_TAG="proc_watcher2"
CHECK_INTERVAL_SEC=30
IGNORE_COMMS="systemd,kthreadd,rcu_sched,gnome-shell,Xorg"
DEBUG="" # DEBUG=1 for print debug in log

# === Мониторинг времени жизни ===
MAX_AGE_HOURS=2


# === Мониторинг CPU ===
CPU_WARN_THRESHOLD=2
CPU_KILL_THRESHOLD=4


